# Copy this file to .env and fill in the values before running.

# ── Django ────────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=crm.solarhopeafrica.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_NAME=solarhope_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your-db-password
DATABASE_HOST=db          # use 'db' when running via docker-compose, 'localhost' otherwise
DATABASE_PORT=5432

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://crm.solarhopeafrica.com

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://crm.solarhopeafrica.com

# ── Email (Gmail App Password) ────────────────────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# ── App ───────────────────────────────────────────────────────────────────────
WHATSAPP_BUSINESS_NUMBER=+250780000000
LOW_STOCK_THRESHOLD=2
